    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "netlify-cli": "^26.0.0",
    "typescript": "^5.5.0",
    "@types/node": "^22.15.30",
    "@netlify/functions": "^5.1.3"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@netlify/blobs": "^8.0.0"
  },
  "packageManager": "yarn@1.22.19"
}